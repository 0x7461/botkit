# Delivery Methods (set to true/false)
ENABLE_TELEGRAM=true
ENABLE_EMAIL=false

# Telegram Bot Configuration
# Each bot has its own token. Use BOT_<NAME>__TOKEN and BOT_<NAME>__CHAT.
# TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID are fallbacks if bot-specific vars are missing.

# Fallback (used if bot-specific vars not set)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=your-chat-id

# gh-bot — GitHub trending weekly report
BOT_GH__TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_GH__CHAT=your-chat-id

# rss-bot — RSS digest
BOT_RSS__TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_RSS__CHAT=your-chat-id

# Gmail SMTP Configuration (optional)
# Get an App Password from: https://myaccount.google.com/apppasswords
# (You need 2-factor authentication enabled)
GMAIL_FROM=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
GMAIL_TO=recipient@example.com
