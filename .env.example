# Delivery Methods (set to true/false)
ENABLE_TELEGRAM=true
ENABLE_EMAIL=false

# Telegram Bot Configuration
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow prompts
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=your-chat-id

# Gmail SMTP Configuration (optional)
# Get an App Password from: https://myaccount.google.com/apppasswords
# (You need 2-factor authentication enabled)
GMAIL_FROM=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
GMAIL_TO=recipient@example.com
